{
	"schemaVersion": 1,
	"id": "gravitywand",
	"version": "${version}",
	"name": "Gravity Wand",
	"description": "A fun mod that adds a Gravity Wand to launch mobs and lift blocks from a distance.",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/gravitywand/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.gravitywand.GravityWandMod"
		],
		"client": [
			"com.gravitywand.client.GravityWandModClient"
		]
	},
	"mixins": [
		"gravitywand.mixins.json",
		{
			"config": "gravitywand.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}